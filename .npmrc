# node-linker=hoisted → node_modules "achatado" (estilo npm) na raiz do
# workspace. Maximiza compatibilidade com libs não pensadas para o layout
# estrito do pnpm (baileys, whatsapp-web.js, puppeteer, nest) e simplifica o
# Docker (basta copiar o node_modules da raiz).
node-linker=hoisted
auto-install-peers=true
strict-peer-dependencies=false
link-workspace-packages=true
prefer-workspace-packages=true
save-exact=false
# Baileys depende de `libsignal` via git — o pnpm 11 bloqueia subdeps git por
# padrão. Liberamos para permitir a instalação do Baileys.
block-exotic-subdeps=false
