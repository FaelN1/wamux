# WAMux — variáveis da stack do Portainer.
#
# No Portainer: aba "Environment variables" do stack (ou "Advanced mode" → cole isto).
# Só as marcadas com (OBRIGATÓRIO) travam o deploy se ficarem vazias; o resto tem
# default sensato dentro do portainer-stack.yml.

# ── Imagens (seu namespace no Docker Hub) ─────────────────────
WAMUX_IMAGE=faeln1/wamux-gateway
WAMUX_WEB_IMAGE=faeln1/wamux-web
WAMUX_WHATSMEOW_IMAGE=faeln1/wamux-whatsmeow
WAMUX_TAG=1.0.0

# ── Segredos ──────────────────────────────────────────────────
# (OBRIGATÓRIO) chave global de admin — use algo forte e único
GLOBAL_API_KEY=
# (OBRIGATÓRIO) master key do sidecar Go — qualquer string forte (uso interno)
WHATSMEOW_MASTER_KEY=

# ── URL pública ───────────────────────────────────────────────
# URL externa deste gateway (usada em QR/links e no callback do sidecar).
# Ponha o domínio real, sem barra no final. Ex.: https://wamux.seudominio.com
PUBLIC_BASE_URL=https://wamux.exemplo.com
WHATSMEOW_CALLBACK_BASE=https://wamux.exemplo.com

# ── Portas publicadas no host ─────────────────────────────────
GATEWAY_PORT=3000
WEB_PORT=8080
RABBITMQ_UI_PORT=15672

# ── Postgres (interno — não exposto ao host) ──────────────────
DB_USER=whatsapp
DB_PASSWORD=troque-esta-senha
DB_NAME=whatsapp_api
WHATSMEOW_DB_NAME=wamux
# Sem migrations ainda: mantenha true para o schema ser criado no boot.
DB_SYNCHRONIZE=true

# ── Redis (interno) ───────────────────────────────────────────
REDIS_PASSWORD=

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_USER=wamux
RABBITMQ_PASS=troque-esta-senha
# Se mudar RABBITMQ_PASS, atualize a senha AQUI também.
RABBITMQ_URI=amqp://wamux:troque-esta-senha@rabbitmq:5672

# ── Opcionais ─────────────────────────────────────────────────
LOG_LEVEL=info
WORKER_ID=worker-1
SESSION_PHONE_CLIENT=WAMux
SESSION_PHONE_NAME=Chrome
MEDIA_STORE=local
CLOUD_API_VERIFY_TOKEN=
WHATSMEOW_SENTRY_DSN=
WHATSMEOW_WEBSHARE_API_KEY=
