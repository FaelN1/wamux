# ─────────────────────────────────────────────────────────────
# App
#
# Self-hosted de verdade: NÃO há licença, ativação manual ou telemetria
# obrigatória. `docker compose up` sobe tudo apenas com este arquivo.
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Chave global de administração (criar/listar instâncias).
# Cada instância também recebe sua própria API key ao ser criada.
# ⚠️ Em NODE_ENV=production o boot FALHA se esta chave ficar no default
#    'change-me' (fail-fast headless — nunca suba com credencial padrão).
GLOBAL_API_KEY=troque-esta-chave-super-secreta

# URL pública deste gateway (base para links/QR e callbacks externos).
# Local: http://localhost:3000 | Docker: injetada pelo compose.
PUBLIC_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Postgres (metadados de instância, credenciais de sessão, mensagens)
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=whatsapp
DB_PASSWORD=whatsapp
DB_NAME=whatsapp_api
# ⚠️ true é SÓ para dev/estudo (sincroniza o schema no boot). Em produção
#    use false + migrations TypeORM — synchronize pode destruir dados.
DB_SYNCHRONIZE=true

# ─────────────────────────────────────────────────────────────
# Persistência do Inbox (contato-chat/mensagens) — opt-in, default OFF.
# Nomes espelham as flags DATABASE_SAVE_* da Evolution API. Sem nenhuma
# ligada, o Inbox degrada de forma graciosa (sem lista de conversas), nunca
# quebra as rotas ao vivo já existentes. Ver docs/inbox-persistencia-handoff.md.
# ─────────────────────────────────────────────────────────────
# Contato-chat (nome/avatar/última msg/unread) — sem isso, sem lista de
# conversas no Inbox.
DATABASE_SAVE_DATA_CONTACTS=false
# ⚠️ GRAVA CONTEÚDO DE MENSAGEM AT-REST (texto/tipo/remetente da thread).
DATABASE_SAVE_DATA_NEW_MESSAGE=false
# Persiste transições de ack/edição/deleção nas mensagens já gravadas.
DATABASE_SAVE_MESSAGE_UPDATE=false
# Persiste também o que vem do import de histórico (history/), além do live.
DATABASE_SAVE_DATA_HISTORIC=false
# Expurgo automático (dias). 0 = nunca expurga.
DATABASE_MESSAGE_RETENTION_DAYS=0
# ⚠️ GRAVA URL DE MÍDIA AT-REST (necessário pra renderizar mídia na thread).
DATABASE_SAVE_MEDIA_BODY=false

# ─────────────────────────────────────────────────────────────
# Pipeline de mídia (onde os BYTES de mídia in/outbound são gravados).
# local (default, zero-config) grava em disco em MEDIA_LOCAL_DIR. s3 grava
# num bucket S3 (ou compatível — MinIO, DigitalOcean Spaces etc); a URL
# servida ao cliente continua sendo a rota do próprio gateway (nunca
# presigned) — só o backend dos bytes muda. Se MEDIA_STORE=s3 mas faltar
# bucket/credenciais, o boot NÃO falha: cai pra local com um aviso no log.
# ─────────────────────────────────────────────────────────────
# local | s3
MEDIA_STORE=local
MEDIA_MAX_SIZE_MB=100
MEDIA_LOCAL_DIR=./data/media
# Endpoint custom (MinIO/Spaces). Vazio = endpoint padrão da AWS.
MEDIA_S3_ENDPOINT=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
# true = path-style (necessário pro MinIO/maioria dos S3-compatíveis).
# AWS S3 real costuma usar virtual-hosted style — nesse caso, false.
MEDIA_S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────
# Painel de Logs/Atividade — opt-in, default OFF. Escopo admin (todas as
# instâncias, autenticado com GLOBAL_API_KEY). Ver docs/logs-painel-handoff.md.
# ─────────────────────────────────────────────────────────────
ACTIVITY_LOG_ENABLED=false
# Expurgo automático (dias). 0 = nunca expurga. Volume aqui tende a ser
# maior que o do Inbox — recomenda-se um valor baixo em produção (ex.: 30).
ACTIVITY_LOG_RETENTION_DAYS=0
# Loga também requisições GET (alto volume, baixo valor de auditoria).
# Mutações (POST/PUT/PATCH/DELETE) sempre logam quando ACTIVITY_LOG_ENABLED=true.
ACTIVITY_LOG_INCLUDE_GET=false

# ─────────────────────────────────────────────────────────────
# Redis (registry de instâncias, filas BullMQ, cache, pub/sub)
# ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────
# RabbitMQ (transporte de eventos "stream" — filtrado por instância)
# ─────────────────────────────────────────────────────────────
# URI de conexão do broker. Docker: injetada pelo compose (usuário/senha abaixo).
RABBITMQ_URI=amqp://wamux:wamux@localhost:5672
# Credenciais do serviço rabbitmq no docker-compose (UI de gestão em :15672).
RABBITMQ_USER=wamux
RABBITMQ_PASS=wamux

# ─────────────────────────────────────────────────────────────
# Rate limit de envio por instância (anti-ban) — token bucket
# ─────────────────────────────────────────────────────────────
# ritmo sustentado (msgs/seg) e rajada (burst)
RATE_LIMIT_PER_SEC=1
RATE_LIMIT_BURST=5

# ─────────────────────────────────────────────────────────────
# Settings globais (defaults; editáveis pelo painel em Configurações)
# ─────────────────────────────────────────────────────────────
# Webhook global: aplicado às instâncias sem webhook próprio.
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
# Identidade no WhatsApp ("Aparelhos conectados") — Baileys.
SESSION_PHONE_CLIENT=WAMux
SESSION_PHONE_NAME=Chrome

# ─────────────────────────────────────────────────────────────
# Identidade deste worker (usado pelo Instance Registry).
# Em multi-worker, cada réplica precisa de um WORKER_ID único.
# ─────────────────────────────────────────────────────────────
WORKER_ID=worker-1

# ─────────────────────────────────────────────────────────────
# whatsmeow sidecar (serviço Go — wamux_go, em services/whatsmeow/)
# ─────────────────────────────────────────────────────────────
# URL do serviço Go. Local: http://localhost:8081 | Docker: http://whatsmeow:3000
WHATSMEOW_URL=http://localhost:8081
# MASTER_API_KEY do serviço Go (precisa bater com a env do serviço Go abaixo)
WHATSMEOW_MASTER_KEY=troque-esta-master-key-do-go
# Base URL pública deste gateway (destino do webhook que o serviço Go chama).
# Local: http://localhost:3000 | Docker: http://gateway:3000
WHATSMEOW_CALLBACK_BASE=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Serviço Go (services/whatsmeow) — usado pelo docker-compose
# ─────────────────────────────────────────────────────────────
# Banco PRÓPRIO do serviço Go (separado do gateway p/ evitar colisão de tabelas)
WHATSMEOW_DB_NAME=wamux
# Opcionais do serviço Go
WHATSMEOW_SENTRY_DSN=
WHATSMEOW_WEBSHARE_API_KEY=

# ─────────────────────────────────────────────────────────────
# WhatsApp Cloud API (oficial / Meta) — valores default por instância,
# podem ser sobrescritos no payload de criação da instância.
# ─────────────────────────────────────────────────────────────
CLOUD_API_VERSION=v21.0
CLOUD_API_BASE_URL=https://graph.facebook.com
# Token usado para validar webhooks de entrada da Meta
CLOUD_API_VERIFY_TOKEN=troque-este-verify-token
